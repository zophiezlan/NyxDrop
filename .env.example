# Copy to .env and fill in. .env is gitignored.

# --- Database ---
# Neon serverless Postgres connection string.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Server ---
NODE_ENV=development
PORT=5000

# --- Guardian admin auth ---
# Random 32+ character string. Used to sign session IDs.
SESSION_SECRET=replace-me-with-a-long-random-string

# Bootstrap token consumed once by scripts/seed-admin.ts to create the
# first super-admin guardian. Rotate or clear after use.
ADMIN_BOOTSTRAP_TOKEN=replace-me-with-a-long-random-string

# --- Web Push (VAPID) ---
# Generate via: npm run -- tsx server/scripts/generate-vapid.ts
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:guardians@example.org

# --- Demo mode ---
# Controls the prototype "Demo data" banners (onboarding modal, persistent
# map chip, detail-sheet strip, now-mode banner, about-page notice). The
# seed dataset uses real organisation names with fabricated reports, so
# this MUST stay on for any deployment of the prototype. Set to "false"
# only when seed.ts is replaced with a real-data ingest.
VITE_DEMO_MODE=true
