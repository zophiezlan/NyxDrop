{
  "name": "naloxone-locate",
  "version": "0.0.0",
  "private": true,
  "description": "A community-sourced map of naloxone access points across Australia.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/scripts/seed.ts",
    "db:seed-reports": "tsx server/scripts/seed-realistic-reports.ts",
    "db:reset-reports": "tsx server/scripts/reset-reports.ts",
    "db:reset-all": "tsx server/scripts/reset-all.ts",
    "db:import-thn": "tsx server/scripts/import-thn.ts",
    "db:import-nsw-nsp": "tsx server/scripts/import-nsw-nsp.ts",
    "db:import-vic-nsp": "tsx server/scripts/import-vic-nsp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "@changey/react-leaflet-markercluster": "^4.0.0-rc1",
    "@neondatabase/serverless": "^0.10.4",
    "@tanstack/query-async-storage-persister": "^5.100.11",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-query-persist-client": "^5.100.11",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.5.1",
    "express": "^4.21.2",
    "idb-keyval": "^6.2.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "web-push": "^3.6.7",
    "wouter": "^3.3.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.15",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
